# --- OpenRouter (LLM provider) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxx

# Models
LLM_MODEL_CONTENT=anthropic/claude-3.5-haiku
LLM_MODEL_CONTENT_FALLBACK=openai/gpt-4o-mini

# --- Storage backend ---
# "sqlite" (default, zero-setup) or "supabase"
DB_BACKEND=sqlite
DB_PATH=./prospects.db

# Only used when DB_BACKEND=supabase
SUPABASE_URL=
SUPABASE_KEY=

# --- Build settings ---
MAX_CONCURRENCY=5
MAX_BUDGET_USD=10.0
OUTPUT_DIR=./dist
TEMPLATES_DIR=./templates

# --- QA settings (Phase 4) ---
# Vision LLM model for QA scoring. Cheap + good vision → Gemini 2.5 Flash.
LLM_MODEL_QA=google/gemini-2.5-flash
QA_SCORE_THRESHOLD=7
QA_VIEWPORT_WIDTH=1440
QA_VIEWPORT_HEIGHT=900
QA_SCREENSHOTS_DIR=./qa_screenshots
QA_CONCURRENCY=3

# --- Cloudflare Pages deploy (Phase 3) ---
# 1. Account ID : dashboard Cloudflare > sidebar droite
# 2. API token : https://dash.cloudflare.com/profile/api-tokens
#    permission requise : Cloudflare Pages — Edit
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=demos
# Optionnel : si tu as configuré un domaine custom dans le dashboard Pages.
# Sinon le builder utilisera l'URL par défaut <project>.pages.dev
PUBLIC_BASE_URL=

# --- Cold email Instantly (Phase 6) ---
# Crée la campagne dans Instantly (UI) avec une séquence dont le sujet et le corps
# référencent {{custom_variables.subject}} et {{custom_variables.body_html}}.
# Le builder pousse les leads dans cette campagne avec leurs variables personnalisées.
INSTANTLY_API_KEY=
INSTANTLY_CAMPAIGN_ID=
INSTANTLY_BASE_URL=https://api.instantly.ai/api/v2

# --- Identité expéditeur (RGPD) ---
# Ces infos sont injectées dans les mentions légales de chaque email envoyé.
# Sans elles, l'envoi est refusé côté code (conformité B2B France).
SENDER_NAME=Alex Dubois
SENDER_ROLE=Cofondateur
SENDER_COMPANY=Mon Agence Web SAS
SENDER_SIREN=903456789
SENDER_ADDRESS=12 rue de la République, 75011 Paris
SENDER_PHONE=+33612345678
SENDER_REPLY_TO=alex@monagenceweb.fr
